<h1>Players</h1>

<% if notice.present? %>
  <p class="notice"><%= notice %></p>
<% end %>

<%= link_to "Add New Player", new_player_path, class: "btn" %>

<% if @players.any? %>
  <table>
    <thead>
      <tr>
        <th>Name</th>
        <th>Gender</th>
        <th></th>
      </tr>
    </thead>
    <tbody>
      <% @players.each do |player| %>
        <tr>
          <td><%= link_to player.name, player_path(player) %></td>
          <td><%= player.gender %></td>
          <td>
            <%= button_to "Remove", player_path(player), method: :delete,
                  data: { turbo_confirm: "Are you sure you want to remove #{player.name}?" },
                  class: "btn btn-danger" %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% else %>
  <p class="empty-state">No players yet. Add one to get started!</p>
<% end %>
